          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Lucía",
              "text": "Bienvenido al Barrio de la Familia. Tu meta es ayudar a este vecindario a reencontrarse antes de la fiesta comunitaria de esta noche."
            },
            {
              "type": "showDialogue",
              "speaker": "Lucía",
              "text": "Empieza en Casa Verde con Ana: ella abre la reconciliación. Después sigue la carta hasta Casa Roja, lleva el cuaderno a Casa Azul y vuelve con ingredientes, historias y acuerdos."
            },
            {
              "type": "showDialogue",
              "speaker": "Lucía",
              "text": "Si logras que la plaza reciba a todos con respeto, Tomás abrirá el repaso y luego los tres duelos familiares."
            },
            {
              "type": "askChoice",
              "prompt": "¿Cuál es el plan principal de Lucía para este capítulo?",
              "options": [
                {
                  "label": "Reconectar a la familia visitando las casas, coordinando la fiesta y llegando preparado al repaso y los duelos.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "showDialogue",
                      "speaker": "Lucía",
                      "text": "Eso es. Ve primero a Casa Verde y no pierdas el hilo entre una casa y otra."
                    },
                    {
                      "type": "addItem",
                      "itemId": "routePass",
                      "count": 1
                    },
                    {
                      "type": "completeMission",
                      "missionId": "family-hub-orientation"
                    }
                  ]
                },
                {
                  "label": "Memorizar palabras aisladas sin visitar a nadie.",
                  "correct": false
                },
                {
                  "label": "Ir a los jefes antes de preparar la reunión del barrio.",
                  "correct": false
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Lucía",
              "text": "Sigue el hilo del reencuentro: Ana, Diego, Sofía y Javier, Elena, la plaza, el repaso y después los duelos."
            }
          ]
        }
      ]
    },
    {
      "personId": "tomás",
      "x": 5,
      "y": 9,
      "interactions": [
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Tomás",
              "text": "En familia, un buen mediador no corre: escucha lo que falta, lo que duele y lo que todavía se puede reparar."
            },
            {
              "type": "showDialogue",
              "speaker": "Tomás",
              "text": "No confundas silencio con indiferencia; a veces alguien calla porque necesita turno, contexto o consuelo."
            }
          ]
        }
      ]
    }
