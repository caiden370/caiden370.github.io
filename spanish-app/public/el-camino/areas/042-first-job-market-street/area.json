          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Carlos",
              "text": "La oficina abrirá una reunión importante y yo coordino a los proveedores del turno."
            },
            {
              "type": "showDialogue",
              "speaker": "Carlos",
              "text": "En otro pedido, alguien trajo comida pero olvidó la herramienta de cálculo; la entrega llegó, pero el cliente no pudo revisar cantidades."
            },
            {
              "type": "showDialogue",
              "speaker": "Carlos",
              "text": "Hoy el encargo está dividido entre Emma, Diego y Lucía. Solo vuelve cuando cada parte quede validada."
            },
            {
              "type": "askChoice",
              "prompt": "Si un pedido se reparte entre tres puestos, ¿qué lo cierra de forma profesional?",
              "options": [
                {
                  "label": "Recojo cada parte, verifico la herramienta y luego lo confirmo contigo.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "showDialogue",
                      "speaker": "Carlos",
                      "text": "Correcto. Sigue la cadena completa."
                    },
                    {
                      "type": "completeMission",
                      "missionId": "firstjob-market-order"
                    }
                  ]
                },
                {
                  "label": "Recojo solo lo más rápido y digo que el resto llegará después.",
                  "correct": false
                },
                {
                  "label": "Vuelvo enseguida aunque la herramienta siga sin revisar.",
                  "correct": false
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
