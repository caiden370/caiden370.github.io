          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Carlos",
              "text": "Ya tienes los tres elementos. Ahora dime el estado de la entrega como lo haría un proveedor serio."
            },
            {
              "type": "showDialogue",
              "speaker": "Carlos",
              "text": "Menciona productos y verificación, no solo que “trajiste cosas”."
            },
            {
              "type": "askText",
              "prompt": "Escribe en español: I brought the milk and bread, and the calculator is already verified.",
              "placeholder": "Respuesta en español",
              "correctAnswers": [
