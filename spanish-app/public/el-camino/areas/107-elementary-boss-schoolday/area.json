              "questions": [
                {
                  "type": "askAudioChoice",
                  "prompt": "Escucha. ¿Qué debe hacer la persona?",
                  "audioText": "Compra leche en la tienda y vuelve a la casa.",
                  "options": [
                    { "label": "Buy milk at the store and return to the house.", "correct": true },
                    { "label": "Read in the library and return a card.", "correct": false },
                    { "label": "Draw a blue triangle in art class.", "correct": false }
                  ]
                },
                {
                  "type": "askText",
                  "prompt": "Write in Spanish: I have the red pencil and the library card.",
                  "placeholder": "Respuesta en español",
                  "correctAnswers": ["Tengo el lápiz rojo y la tarjeta de biblioteca", "Tengo el lapiz rojo y la tarjeta de biblioteca"]
                },
                {
                  "type": "askChoice",
                  "prompt": "En la cafetería, alguien dice: Quiero dos panes, pero no tengo monedas. ¿Cuál es el problema?",
                  "options": [
                    { "label": "Quiere comprar pan pero no tiene dinero.", "correct": true },
                    { "label": "Quiere jugar pero no conoce el patio.", "correct": false },
                    { "label": "Tiene una tarjeta pero no un libro.", "correct": false }
                  ]
                },
                {
                  "type": "askChoice",
                  "prompt": "Conversación: --¿Tienes agua para la maestra? --Sí, la tengo. --Entonces, tráela al aula. ¿Qué debe llevar?",
                  "options": [
                    { "label": "El agua al aula.", "correct": true },
                    { "label": "Un cartel al patio.", "correct": false },
                    { "label": "Pan a la biblioteca.", "correct": false }
                  ]
                },
                {
                  "type": "askChoice",
                  "prompt": "En el capítulo, ¿dónde se practica silencio, lee y escucha?",
                  "options": [
                    { "label": "En la biblioteca.", "correct": true },
                    { "label": "En la cafetería.", "correct": false },
                    { "label": "En el camino de tierra.", "correct": false }
                  ]
                }
              ],
              "actions": [
                { "type": "showDialogue", "speaker": "Guardián del Patio", "text": "Segundo duelo completo." },
                { "type": "completeMission", "missionId": "elem-boss-schoolday" }
              ]
            }
          ]
        },
        { "actions": [{ "type": "showDialogue", "speaker": "Guardián del Patio", "text": "Cruza a la Biblioteca final." }] }
      ]
    }
  ],
  "exits": [
    { "x": 0, "y": 5, "targetArea": "elementary-boss-greetings", "targetX": 14, "targetY": 5, "facing": "left" },
    { "x": 15, "y": 5, "targetArea": "elementary-boss-final", "targetX": 1, "targetY": 5, "facing": "right", "requires": { "completedMissions": ["elem-boss-schoolday"] }, "blockedMessage": "Derrota primero al Guardián del Patio." }
