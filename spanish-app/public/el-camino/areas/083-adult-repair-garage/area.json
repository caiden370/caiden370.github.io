              "garage-checkin"
            ]
          },
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Diego",
              "text": "Cuando alguien dice 'el coche suena raro', eso no sirve. Un ingreso técnico útil identifica síntoma, contexto y urgencia."
            },
            {
              "type": "showDialogue",
              "speaker": "Diego",
              "text": "Ayer llegó un auto con ruido leve solo al arrancar; ese caso no se trata igual que una falla al frenar en carretera."
            },
            {
              "type": "askChoice",
              "prompt": "Para abrir una orden responsable en este taller, ¿qué debe quedar escrito desde el check-in?",
              "options": [
                {
                  "label": "Síntoma principal, condiciones de uso y urgencia del cliente.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "addItem",
                      "itemId": "notebook",
                      "count": 1
                    },
                    {
                      "type": "showDialogue",
                      "speaker": "Diego",
                      "text": "Correcto. Sin ese registro, cualquier diagnóstico se vuelve discutible."
                    },
                    {
                      "type": "completeMission",
                      "missionId": "garage-checkin"
                    }
                  ]
                },
                {
                  "label": "Solo color del auto y música favorita.",
                  "correct": false
                },
                {
                  "label": "Ningún dato, para ahorrar tiempo.",
                  "correct": false
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Diego",
              "text": "Sin diagnóstico escrito, no autorizo reparación."
            }
          ]
        }
      ]
    },
    {
      "personId": "carlos",
      "x": 12,
      "y": 5,
      "interactions": [
        {
          "when": {
            "completedMissions": [
              "garage-checkin"
            ],
            "missingMissions": [
              "garage-parts-order"
            ]
          },
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Carlos",
              "text": "En un taller adulto no se negocia contra la física: primero va lo que compromete seguridad, después lo cosmético o diferible."
            },
            {
              "type": "showDialogue",
              "speaker": "Carlos",
              "text": "Un retrovisor rayado molesta; unos frenos inestables cambian toda la prioridad del caso."
            },
            {
              "type": "askAudioChoice",
              "prompt": "Escucha el reporte del técnico.",
              "audioText": "El freno trasero responde tarde y la vibración aumenta en bajadas largas; el cambio de aceite puede esperar una semana.",
              "options": [
                {
                  "label": "Priorizar frenos y vibración antes de mantenimiento menor.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "addItem",
                      "itemId": "pencil",
                      "count": 1
                    },
                    {
                      "type": "showDialogue",
                      "speaker": "Carlos",
                      "text": "Exacto. Esa orden de piezas protege al cliente y también tu credibilidad."
                    },
                    {
                      "type": "completeMission",
                      "missionId": "garage-parts-order"
                    }
                  ]
                },
                {
                  "label": "Cambiar aceite primero y posponer frenos.",
                  "correct": false
                },
                {
                  "label": "No hacer nada hasta el próximo mes.",
                  "correct": false
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Carlos",
              "text": "Una mala prioridad aquí puede costar mucho en la carretera."
            }
          ]
        }
      ]
    },
    {
      "personId": "emma",
      "x": 18,
      "y": 5,
      "interactions": [
