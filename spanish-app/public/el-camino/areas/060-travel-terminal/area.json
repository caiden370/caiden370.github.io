          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Marcos",
              "text": "Tu cadena está casi lista: documentos, control, reserva y orientación urbana."
            },
            {
              "type": "askChoice",
              "prompt": "¿Qué resumen refleja la cadena completa del terminal?",
              "options": [
                {
                  "label": "Documentos correctos, control superado, reserva confirmada y rutas comprendidas.",
                  "correct": true,
                  "actions": [
                    { "type": "showDialogue", "speaker": "Marcos", "text": "Perfecto. Se abre el centro de repaso." },
                    { "type": "completeMission", "missionId": "travel-terminal-brief" }
                  ]
                },
                { "label": "Café primero, luego improvisar todo lo demás.", "correct": false },
                { "label": "Saltar seguridad porque ya tienes maleta.", "correct": false }
