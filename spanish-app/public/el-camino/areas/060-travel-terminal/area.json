                },
                { "label": "Ir directo al hotel y pedir la llave.", "correct": false },
                { "label": "Entrar al avión sin informar el destino.", "correct": false }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Valeria",
              "text": "Orden recomendado: facturación, seguridad, hotel y repaso."
            }
          ]
        }
      ]
    },
    {
      "personId": "marcos",
      "x": 16,
      "y": 9,
      "interactions": [
        {
          "when": {
            "completedMissions": ["travel-security-clearance", "travel-hotel-complete", "travel-directions"],
