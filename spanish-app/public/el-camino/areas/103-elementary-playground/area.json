              "options": [
                {
                  "label": "detenerse",
                  "correct": true,
                  "actions": [
                    { "type": "showDialogue", "speaker": "Diego", "text": "Correcto. Para es detenerse." },
                    {
                      "type": "askChoice",
                      "prompt": "Si Diego dice salta, ¿qué acción corresponde?",
                      "options": [
                        { "label": "jump", "correct": true, "actions": [
                          { "type": "showDialogue", "speaker": "Diego", "text": "Bien. Ya entiendes las órdenes del patio." },
                          { "type": "completeMission", "missionId": "elem-actions" }
                        ] },
                        { "label": "stop", "correct": false },
                        { "label": "read", "correct": false }
                      ],
                      "wrongMessage": "No. Intenta otra vez."
                    }
                  ]
                },
                { "label": "correr", "correct": false },
                { "label": "leer", "correct": false }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        { "actions": [{ "type": "showDialogue", "speaker": "Diego", "text": "Corre, camina, salta, para." }] }
      ]
    },
    {
      "personId": "nico",
      "x": 8,
      "y": 8,
      "interactions": [
        {
          "when": { "completedMissions": ["elem-actions"], "missingMissions": ["elem-likes"] },
          "actions": [
            { "type": "showDialogue", "speaker": "Nico", "text": "Me gusta jugar con la pelota. No me gusta esperar mucho." },
            { "type": "showDialogue", "speaker": "Nico", "text": "Lucía perdió un juguete. Si la ayudas, todos podemos jugar." },
            {
              "type": "askChoice",
              "prompt": "Nico says: Me gusta jugar. What does he mean?",
              "options": [
                { "label": "He likes to play.", "correct": true, "actions": [
                  { "type": "showDialogue", "speaker": "Nico", "text": "Sí. Me gusta jugar." },
                  { "type": "completeMission", "missionId": "elem-likes" }
                ] },
                { "label": "He needs a book.", "correct": false },
                { "label": "He is tired.", "correct": false }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        { "actions": [{ "type": "showDialogue", "speaker": "Nico", "text": "Me gusta jugar. Busca el juguete de Lucía." }] }
      ]
    },
    {
      "personId": "lucia",
      "x": 20,
      "y": 8,
      "interactions": [
        {
          "when": { "hasItems": [{ "itemId": "lostToy", "count": 1 }], "completedMissions": ["elem-likes"], "missingMissions": ["elem-lost-toy"] },
          "actions": [
            { "type": "showDialogue", "speaker": "Lucía", "text": "Mi juguete estaba perdido. Ahora está aquí. ¡Gracias!" },
            { "type": "showDialogue", "speaker": "Lucía", "text": "Cuando alguien ayuda, la respuesta amable es gracias." },
            {
              "type": "askText",
              "prompt": "Responde con la palabra amable apropiada.",
              "placeholder": "Respuesta en español",
              "correctAnswers": ["gracias"],
              "actions": [
                { "type": "showDialogue", "speaker": "Lucía", "text": "Gracias. Ahora busca la pelota para Carlos." },
                { "type": "removeItem", "itemId": "lostToy", "count": 1 },
                { "type": "completeMission", "missionId": "elem-lost-toy" }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        { "actions": [{ "type": "showDialogue", "speaker": "Lucía", "text": "Busco un juguete perdido." }] }
      ]
    },
    {
      "personId": "carlos",
      "x": 14,
      "y": 12,
      "interactions": [
        {
          "when": { "hasItems": [{ "itemId": "playgroundBall", "count": 1 }], "completedMissions": ["elem-actions", "elem-likes", "elem-lost-toy"], "missingMissions": ["elem-playground-complete"] },
          "actions": [
            { "type": "showDialogue", "speaker": "Carlos", "text": "Diego dio órdenes. Nico dijo qué le gusta. Lucía recuperó su juguete." },
            { "type": "showDialogue", "speaker": "Carlos", "text": "Ahora con la pelota podemos jugar. Responde como estudiante del patio." },
            {
              "type": "askSpeech",
              "prompt": "Di una frase sobre lo que te gusta hacer en el patio.",
              "placeholder": "Respuesta hablada",
              "correctAnswers": ["Me gusta jugar", "Me gusta correr", "Me gusta saltar"],
              "actions": [
                { "type": "showDialogue", "speaker": "Carlos", "text": "Patio completo. Muy bien." },
                { "type": "completeMission", "missionId": "elem-playground-complete" }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        { "actions": [{ "type": "showDialogue", "speaker": "Carlos", "text": "Necesitamos juguete, pelota y práctica." }] }
