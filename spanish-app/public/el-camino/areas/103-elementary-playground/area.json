          "when": { "missingMissions": ["elem-actions"] },
          "actions": [
            { "type": "showDialogue", "speaker": "Diego", "text": "Soy el entrenador del patio. Cuando digo corre, te mueves rápido." },
            { "type": "showDialogue", "speaker": "Diego", "text": "Cuando digo para, te detienes. Cuando digo salta, subes y bajas." },
            {
              "type": "askAudioChoice",
              "prompt": "Escucha la orden. ¿Qué debe hacer el estudiante?",
