            ]
          },
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Valeria",
              "text": "Abrir el micrófono no es dar un discurso perfecto; es crear un tono donde caben alegría, cansancio y tensión."
            },
            {
              "type": "showDialogue",
              "speaker": "Valeria",
              "text": "Yo siempre empiezo agradeciendo la presencia y recordando la regla de respeto."
            },
            {
              "type": "showDialogue",
              "speaker": "Valeria",
              "text": "Haz una apertura breve, cálida y firme."
            },
            {
              "type": "askSpeech",
              "prompt": "Say in Spanish: Gracias por venir; vamos a escucharnos con respeto.",
              "placeholder": "Respuesta hablada",
              "correctAnswers": [
                "Gracias por venir vamos a escucharnos con respeto",
                "Gracias por venir; vamos a escucharnos con respeto"
              ],
              "actions": [
                {
                  "type": "addItem",
                  "itemId": "coffeeCup",
                  "count": 1
                },
                {
                  "type": "showDialogue",
                  "speaker": "Valeria",
                  "text": "Perfecto. Ya puedes ir con Marcos para cerrar el programa de la fiesta."
                },
                {
                  "type": "completeMission",
                  "missionId": "family-plaza-voices"
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Valeria",
              "text": "Carlos reparte el pase cuando el menú común ya tiene orden."
            }
          ]
        }
      ]
    },
    {
      "personId": "marcos",
      "x": 22,
