          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Marcos",
              "text": "Ya tienes ingredientes, apertura y confirmación de que la Casa Verde volverá a sentar a todos en la misma mesa."
            },
            {
              "type": "showDialogue",
              "speaker": "Marcos",
              "text": "Lo que falta es una síntesis que una comida, relatos y acuerdos futuros."
            },
            {
              "type": "showDialogue",
              "speaker": "Marcos",
              "text": "No copies frases sueltas: ordénalo como lo haría una persona que modera de verdad."
