          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Elena",
              "text": "En la clínica no esperamos al cansancio extremo. Un buen plan de salud se arma cuando todavía tienes energía para sostener la semana."
            },
            {
              "type": "showDialogue",
              "speaker": "Elena",
              "text": "La manzana sirve como recordatorio: comer mejor y beber agua a tiempo evita errores cuando luego vuelves a revisar documentos."
            },
            {
              "type": "askAudioChoice",
              "prompt": "Escucha. ¿Qué plan recomienda Elena?",
              "audioText": "Debes hidratarte durante el día, caminar treinta minutos y dormir al menos siete horas para sostener una rutina estable.",
              "options": [
                {
                  "label": "Hidratarse, caminar y dormir al menos siete horas.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "removeItem",
                      "itemId": "apple",
                      "count": 1
                    },
                    {
                      "type": "addItem",
                      "itemId": "gymPass",
                      "count": 1
                    },
                    {
                      "type": "addItem",
                      "itemId": "waterBottle",
                      "count": 1
                    },
                    {
                      "type": "showDialogue",
                      "speaker": "Elena",
                      "text": "Plan de salud registrado."
                    },
                    {
                      "type": "completeMission",
                      "missionId": "independent-health-plan"
                    }
                  ]
                },
                {
                  "label": "Ayunar, correr de noche y dormir cuatro horas.",
                  "correct": false
                },
                {
                  "label": "Tomar café todo el día y saltar comidas.",
                  "correct": false
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Elena",
              "text": "Necesito una manzana para completar tu expediente nutricional y registrar hábitos."
            }
          ]
        }
      ]
    },
