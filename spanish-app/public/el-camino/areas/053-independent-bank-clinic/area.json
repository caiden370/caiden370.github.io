          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Javier",
              "text": "Cuando un vecino paga el alquiler aquí, primero explica el motivo de la transferencia y luego confirma identidad y monto. Así evitamos comprobantes incompletos."
            },
            {
              "type": "showDialogue",
              "speaker": "Javier",
              "text": "Si falta uno de esos datos, el dinero puede salir igual, pero el expediente no queda claro para la auditoría."
            },
            {
              "type": "askChoice",
              "prompt": "Si el banco ya vio tu tarjeta pero aún no entiende para qué es el pago, ¿qué falta antes de aprobar la transferencia?",
              "options": [
                {
                  "label": "Confirmar el monto y explicar que es una transferencia de alquiler para recibir comprobante.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "showDialogue",
                      "speaker": "Javier",
                      "text": "Correcto. Aquí está tu comprobante bancario para el expediente del apartamento."
                    },
                    {
                      "type": "addItem",
                      "itemId": "routePass",
                      "count": 1
                    },
                    {
                      "type": "completeMission",
                      "missionId": "independent-bank-transfer"
                    }
                  ]
                },
                {
                  "label": "Retirar efectivo sin registrar el concepto del pago.",
                  "correct": false
                },
                {
                  "label": "Salir del banco y esperar que otra persona lo explique.",
                  "correct": false
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Javier",
              "text": "Trae tu tarjeta y prepárate para explicar monto y concepto de la transferencia."
            }
          ]
        }
      ]
    },
    {
