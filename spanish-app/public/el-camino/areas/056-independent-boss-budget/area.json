                    {
                      "label": "Priorizar necesidades antes de gastos opcionales.",
                      "correct": true
                    },
                    {
                      "label": "Gastar primero en ocio y luego improvisar pagos fijos.",
                      "correct": false
                    },
                    {
                      "label": "Evitar todo registro para decidir más rápido.",
                      "correct": false
                    }
                  ]
                },
                {
