          "actions": [
            {
              "type": "askAudioChoice",
              "prompt": "Emma says a bakery word. What did you hear?",
              "audioText": "pan",
              "options": [
                {
                  "label": "pan",
                  "correct": true,
                  "actions": [
                    { "type": "showDialogue", "speaker": "Emma", "text": "Correct. Pan means bread." },
                    { "type": "completeStep", "stepId": "heard-market-foods" }
                  ]
                },
                { "label": "agua", "correct": false },
                { "label": "hola", "correct": false }
              ],
              "wrongMessage": "Listen again. The word is pan."
            }
          ]
        },
        {
          "when": {
            "completedSteps": ["heard-market-foods"],
            "missingSteps": ["bought-bread"],
            "hasItems": [{ "itemId": "coins", "count": 2 }]
          },
          "actions": [
            {
              "type": "askSpeech",
              "prompt": "Say the order to Emma: Quiero pan, por favor.",
              "audioText": "Quiero pan, por favor.",
              "correctAnswers": ["Quiero pan por favor", "Quiero pan, por favor."],
              "actions": [
                { "type": "removeItem", "itemId": "coins", "count": 2 },
                { "type": "addItem", "itemId": "bread", "count": 1 },
                { "type": "completeStep", "stepId": "bought-bread" },
                { "type": "showDialogue", "speaker": "Emma", "text": "Aquí tienes pan. Bring it to Lucía." }
              ],
              "wrongMessage": "Try saying: Quiero pan, por favor."
            }
          ]
        },
        {
          "when": { "completedSteps": ["bought-bread"], "missingMissions": ["market-breakfast"] },
          "actions": [{ "type": "showDialogue", "speaker": "Emma", "text": "You have pan. Bring it to Lucía outside." }]
        },
        {
          "actions": [{ "type": "showDialogue", "speaker": "Emma", "text": "Hola. Lucía may need something from the bakery." }]
        }
      ]
    }
