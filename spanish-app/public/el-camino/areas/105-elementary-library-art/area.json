              "actions": [
                { "type": "showDialogue", "speaker": "Ana", "text": "Silencio. Muy bien." },
                { "type": "completeMission", "missionId": "elem-library-card" }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        { "actions": [{ "type": "showDialogue", "speaker": "Ana", "text": "Necesitas una tarjeta y práctica de formas." }] }
