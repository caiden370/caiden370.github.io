            "completedMissions": [
              "independent-park-delivery"
            ],
            "missingMissions": [
              "independent-neighbor-delivered"
            ]
          },
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Nico",
              "text": "Llegaste justo a tiempo. Cuando alguien avisa y cumple, yo puedo reorganizar mi turno sin estrés."
            },
            {
              "type": "showDialogue",
              "speaker": "Nico",
              "text": "Lo importante no es solo la bolsa; es saber que el vecino entiende horarios y responde con claridad."
            },
            {
              "type": "askChoice",
              "prompt": "¿Qué le conviene a Nico en una comunidad confiable?",
              "options": [
                {
                  "label": "Que las personas entreguen a tiempo y confirmen cualquier cambio con claridad.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "removeItem",
