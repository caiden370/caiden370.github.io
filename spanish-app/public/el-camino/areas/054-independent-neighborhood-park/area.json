                    },
                    {
                      "type": "showDialogue",
                      "speaker": "Nico",
                      "text": "Toma este café para el repaso. Ya veo que también sabes cuidar al vecindario."
                    },
                    {
                      "type": "completeMission",
                      "missionId": "independent-neighbor-delivered"
                    }
                  ]
                },
                {
                  "label": "Que nadie avise y que todos improvisen las entregas.",
                  "correct": false
                },
                {
                  "label": "Que el banco resuelva los encargos del parque.",
                  "correct": false
