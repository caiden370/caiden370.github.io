          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Diego",
              "text": "Nico me escribió desde el trabajo: sale tarde y solo puede recibir el pedido si alguien coordina bien la hora."
            },
            {
              "type": "showDialogue",
              "speaker": "Diego",
              "text": "Este encargo conecta lo que compraste en el supermercado con tu reputación en el barrio. No basta con comprar; hay que cumplir y avisar."
            },
            {
              "type": "askChoice",
              "prompt": "Si sales del súper a las cinco y media, ¿qué debes priorizar?",
              "options": [
                {
                  "label": "Ir con pan y leche al parque, entregarlos a tiempo y confirmar el horario con Nico.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "completeMission",
                      "missionId": "independent-park-delivery"
                    }
                  ]
                },
                {
                  "label": "Volver al apartamento y dejar la entrega para otro día.",
                  "correct": false
                },
                {
                  "label": "Ignorar el horario y llevar solo una botella de agua.",
                  "correct": false
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "when": {
            "completedMissions": [
              "independent-neighbor-delivered"
            ],
            "missingMissions": [
              "independent-park-complete"
            ]
          },
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Diego",
              "text": "Nico confirmó la entrega. Ahora explica el favor como si reportaras el recado a una vecina del edificio."
            },
            {
              "type": "askText",
              "prompt": "Write in Spanish: I delivered the order on time and confirmed the schedule with the neighbor.",
              "placeholder": "Respuesta en español",
              "correctAnswers": [
                "Entregué el pedido a tiempo y confirmé el horario con el vecino",
                "Entregue el pedido a tiempo y confirme el horario con el vecino"
              ],
              "actions": [
                {
                  "type": "showDialogue",
                  "speaker": "Diego",
                  "text": "Bien. Ya demostraste que también sabes responder al barrio."
                },
                {
                  "type": "completeMission",
                  "missionId": "independent-park-complete"
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Diego",
              "text": "Primero coordina la entrega con Nico y luego vuelve para confirmar el recado."
            }
          ]
        }
      ]
    },
    {
      "personId": "nico",
      "x": 20,
      "y": 14,
      "interactions": [
