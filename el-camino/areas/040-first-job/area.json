          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Valeria",
              "text": "Bienvenido al distrito laboral. Hoy no estudias teoría: hoy trabajas con clientes reales."
            },
            {
              "type": "showDialogue",
              "speaker": "Valeria",
              "text": "Tu meta es coordinar cuatro estaciones: oficina, calle del mercado, recepción y sala de descanso."
            },
            {
              "type": "showDialogue",
              "speaker": "Valeria",
              "text": "Escucha bien: recoge materiales, entrégalos, verifica instrucciones y vuelve para el repaso."
            },
            {
              "type": "askChoice",
              "prompt": "¿Qué debes completar antes del repaso final?",
              "options": [
                {
                  "label": "Las cuatro estaciones del turno.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "showDialogue",
                      "speaker": "Valeria",
                      "text": "Exacto. Toma tu etiqueta y empieza con enfoque."
                    },
                    {
                      "type": "addItem",
                      "itemId": "nameTag",
                      "count": 1
                    },
                    {
                      "type": "completeMission",
                      "missionId": "firstjob-started"
                    }
                  ]
                },
                {
                  "label": "Solo hablar con un jefe y volver.",
                  "correct": false
                },
                {
                  "label": "Comprar café y terminar el capítulo.",
                  "correct": false
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Valeria",
              "text": "Cuando cierres las cuatro estaciones, sube al repaso del turno."
            }
          ]
        }
      ]
    },
