          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Isabel",
              "text": "Recibí una factura duplicada. Si nadie la corrige, podría pagar dos veces."
            },
            {
              "type": "showDialogue",
              "speaker": "Isabel",
              "text": "No necesito una excusa larga; necesito una acción y el documento correcto."
            },
            {
              "type": "askText",
              "prompt": "Escribe en español: I will review your invoice and send a corrected copy.",
