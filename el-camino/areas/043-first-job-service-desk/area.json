              "correctAnswers": [
                "Revisaré su factura y enviaré una copia corregida",
                "Revisare su factura y enviare una copia corregida"
              ],
              "actions": [
                {
                  "type": "showDialogue",
                  "speaker": "Isabel",
                  "text": "Gracias. Eso suena claro y responsable."
                },
                {
                  "type": "completeStep",
                  "stepId": "firstjob-client-isabel"
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Isabel",
              "text": "Quiero una acción concreta, no una promesa vacía."
