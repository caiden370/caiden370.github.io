                "Revise ambos casos y hare seguimiento hoy"
              ],
              "actions": [
                {
                  "type": "showDialogue",
                  "speaker": "Sofia",
                  "text": "Excelente cierre. Recepción completada."
                },
                {
                  "type": "completeMission",
                  "missionId": "firstjob-service-resolution"
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Sofia",
              "text": "Necesito resumen de Nico e Isabel, y el manual actualizado para la oficina."
            }
