                  "label": "Revisaré la pieza faltante y te confirmaré la hora exacta hoy.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "showDialogue",
                      "speaker": "Nico",
                      "text": "Eso sí es seguimiento."
                    },
                    {
                      "type": "completeStep",
                      "stepId": "firstjob-client-nico"
                    }
                  ]
                },
                {
                  "label": "No sé qué pasó; quizá mañana.",
                  "correct": false
                },
                {
                  "label": "No puedo ayudarte con eso.",
                  "correct": false
