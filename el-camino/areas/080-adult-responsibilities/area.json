          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Marcos",
              "text": "Ya reuniste licencia, póliza, cierre técnico y verificación documental."
            },
            {
              "type": "showDialogue",
              "speaker": "Marcos",
              "text": "Ahora no colecciones más sellos: cruza al centro de repaso y demuestra que entiendes la lógica completa del caso."
            }
          ]
        },
        {
          "when": {
            "completedMissions": [
              "adult-review-complete"
            ],
            "missingMissions": [
              "adult-boss-bureaucracy"
            ]
          },
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Marcos",
              "text": "El repaso ya certificó tu expediente."
            },
            {
              "type": "showDialogue",
              "speaker": "Marcos",
              "text": "A la derecha te espera la cadena de jefes: primero burocracia, luego negociación y al final el tribunal."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Marcos",
              "text": "Trae evidencia que se pueda defender: formulario, cita, revisión técnica y expediente sellado."
            },
            {
              "type": "showDialogue",
              "speaker": "Marcos",
              "text": "Aquí no basta con llevar papeles; tienes que entender por qué cada comprobante abre el siguiente paso."
            }
          ]
        }
      ]
