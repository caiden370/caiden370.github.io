      "interactions": [
        {
          "when": {
            "hasItems": [
              {
                "itemId": "rosaLetter",
                "count": 1
              }
            ],
            "missingMissions": [
              "family-roja-story-list"
            ]
          },
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Diego",
              "text": "La carta no me pidió olvidar nada. Me recordó una tarde en la que todos escucharon sin competir."
            },
            {
              "type": "showDialogue",
              "speaker": "Diego",
              "text": "Cuando alguien empieza así, uno baja la defensa y por fin puede contar la historia completa."
            },
            {
              "type": "showDialogue",
              "speaker": "Diego",
              "text": "Voy a ordenar los relatos para que nadie quede borrado en la fiesta de esta noche."
            },
            {
              "type": "askText",
              "prompt": "Write in Spanish: Your letter moved me, and I want to listen first.",
              "placeholder": "Respuesta en español",
              "correctAnswers": [
                "Tu carta me emocionó y quiero escuchar primero",
                "Tu carta me emociono y quiero escuchar primero"
              ],
              "actions": [
                {
                  "type": "removeItem",
                  "itemId": "rosaLetter",
                  "count": 1
                },
                {
                  "type": "addItem",
                  "itemId": "notebook",
                  "count": 1
                },
                {
                  "type": "showDialogue",
                  "speaker": "Diego",
                  "text": "Gracias. Lleva este cuaderno a Sofía en la Casa Azul; ella convertirá los relatos en turnos claros."
                },
                {
                  "type": "completeMission",
                  "missionId": "family-roja-story-list"
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "when": {
            "completedMissions": [
              "family-roja-story-list"
            ],
            "missingMissions": [
              "family-roja-bread"
            ]
          },
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Diego",
              "text": "El cuaderno ya va hacia Casa Azul. Cuando Sofía termine, vuelve con leche para que Elena cierre la mesa."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Diego",
              "text": "Leer una carta con calma puede cambiar toda una conversación."
            }
          ]
        }
      ]
    },
    {
      "personId": "elena",
      "x": 13,
      "y": 8,
      "interactions": [
        {
          "when": {
            "completedMissions": [
              "family-roja-story-list"
            ],
            "hasItems": [
              {
                "itemId": "milk",
                "count": 1
              }
            ],
            "missingMissions": [
              "family-roja-bread"
            ]
          },
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Elena",
              "text": "Cuando dos primos discuten por una frase, casi nunca discuten solo por esa frase; discuten por la intención que imaginaron detrás."
            },
            {
              "type": "showDialogue",
              "speaker": "Elena",
              "text": "En otra cena pregunté primero desde qué cansancio había hablado cada persona, y la tensión bajó sola."
            },
            {
              "type": "showDialogue",
              "speaker": "Elena",
              "text": "Haz eso aquí: aclara contexto antes de decidir quién tiene razón."
            },
            {
              "type": "askChoice",
              "prompt": "En una conversación tensa, ¿qué conviene hacer antes de debatir el contenido?",
              "options": [
                {
                  "label": "Aclarar el contexto y la intención para entenderse mejor.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "addItem",
                      "itemId": "bread",
                      "count": 1
                    },
                    {
                      "type": "showDialogue",
                      "speaker": "Elena",
                      "text": "Exacto. Lleva este pan a Ana y a Carlos: sin contexto claro, la mesa común no aguanta."
                    },
                    {
                      "type": "completeMission",
                      "missionId": "family-roja-bread"
                    }
                  ]
                },
                {
                  "label": "Hablar todos a la vez para que nadie pierda turno.",
                  "correct": false
                },
                {
                  "label": "Evitar emociones y cambiar de tema de inmediato.",
                  "correct": false
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "when": {
            "completedMissions": [
              "family-roja-story-list"
            ],
            "missingMissions": [
              "family-roja-bread"
            ]
          },
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Elena",
              "text": "Sofía te espera con la leche en la Casa Azul. Sin esa parada, aquí no cerramos la cena."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Elena",
              "text": "Empieza con la carta de Ana y vuelve cuando la cocina también tenga contexto."
            }
          ]
        }
      ]
    }
