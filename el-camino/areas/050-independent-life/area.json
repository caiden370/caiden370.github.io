  "people": [
    {
      "personId": "isabel",
      "x": 15,
      "y": 11,
      "interactions": [
        {
          "when": {
            "missingMissions": [
              "independent-orientation"
            ]
          },
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Isabel",
              "text": "Hoy empiezas tu vida independiente. Nadie te va a recordar cada paso: tú debes organizar compras, pagos, citas y entregas."
            },
            {
              "type": "showDialogue",
              "speaker": "Isabel",
              "text": "El plan real tiene varios lugares conectados. Si fallas un detalle, el trámite completo se retrasa."
            },
            {
              "type": "showDialogue",
              "speaker": "Isabel",
              "text": "Empieza por hablar con Tomás para conseguir tu identificación y luego entra al apartamento para revisar los documentos."
            },
            {
              "type": "askChoice",
              "prompt": "¿Cuál es la idea principal de Isabel?",
              "options": [
                {
                  "label": "Debes coordinar tareas en varios lugares, no solo una conversación.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "showDialogue",
                      "speaker": "Isabel",
                      "text": "Exacto. Toma este cuaderno para anotar cada trámite."
                    },
                    {
                      "type": "addItem",
                      "itemId": "notebook",
                      "count": 1
                    },
                    {
                      "type": "completeMission",
                      "missionId": "independent-orientation"
                    }
                  ]
                },
                {
                  "label": "Solo necesitas comprar café y descansar.",
                  "correct": false
                },
                {
                  "label": "La clínica y el banco no importan para vivir solo.",
                  "correct": false
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Isabel",
              "text": "Haz cada recado con calma y verifica todo antes del repaso."
            }
          ]
        }
      ]
    },
    {
      "personId": "tomás",
      "x": 12,
      "y": 15,
      "interactions": [
        {
          "when": {
            "completedMissions": [
              "independent-orientation"
            ],
            "missingMissions": [
              "independent-docs-id"
            ]
          },
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Tomás",
              "text": "Sin identificación no puedes hacer transferencia ni abrir expediente médico."
            },
            {
              "type": "showDialogue",
              "speaker": "Tomás",
              "text": "Escucha la frase completa: Necesito mi tarjeta para autorizar pagos y confirmar mis datos personales."
            },
            {
              "type": "askText",
              "prompt": "Translate to Spanish: I need my card to confirm my personal data.",
              "placeholder": "Respuesta en español",
              "correctAnswers": [
                "Necesito mi tarjeta para confirmar mis datos personales",
                "Necesito la tarjeta para confirmar mis datos personales"
              ],
              "actions": [
                {
                  "type": "showDialogue",
                  "speaker": "Tomás",
                  "text": "Perfecto. Aquí tienes la tarjeta."
                },
                {
                  "type": "addItem",
                  "itemId": "nameCard",
                  "count": 1
                },
                {
                  "type": "completeMission",
                  "missionId": "independent-docs-id"
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Tomás",
              "text": "Lleva tu tarjeta al banco y guarda una copia del trámite."
            }
          ]
        }
      ]
    },
    {
      "personId": "lucia",
      "x": 18,
      "y": 15,
      "interactions": [
        {
          "when": {
            "completedMissions": [
              "independent-docs-id"
            ],
            "missingMissions": [
              "independent-hub-check"
            ]
          },
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Lucia",
              "text": "Antes del repaso final, necesitas cuatro verificaciones: apartamento, supermercado, banco-clínica y parque."
            },
            {
              "type": "askChoice",
              "prompt": "¿Qué bloque abre la puerta al repaso?",
              "options": [
                {
                  "label": "Completar las cuatro verificaciones principales.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "completeMission",
                      "missionId": "independent-hub-check"
                    }
                  ]
                },
                {
                  "label": "Terminar solo el supermercado.",
                  "correct": false
                },
                {
                  "label": "Hablar una vez con cada NPC sin entregar nada.",
                  "correct": false
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
            }
          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Lucia",
              "text": "El portón del repaso se abre al completar todas las verificaciones."
            }
          ]
        }
      ]
    }
