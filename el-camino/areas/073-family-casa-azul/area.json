          ]
        },
        {
          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Sofía",
              "text": "Diego guarda el cuaderno en la Casa Roja. Tráelo y organizamos la ronda."
            }
          ]
        }
      ]
    },
    {
