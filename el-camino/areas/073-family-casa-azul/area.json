          "actions": [
            {
              "type": "showDialogue",
              "speaker": "Sofía",
              "text": "En una sobremesa difícil, moderar no es mandar; es notar quién aún no habló y quién necesita una respuesta."
            },
            {
              "type": "showDialogue",
              "speaker": "Sofía",
              "text": "La última vez usé un cuaderno para repartir turnos y nadie tuvo que gritar para existir."
            },
            {
              "type": "showDialogue",
              "speaker": "Sofía",
              "text": "Si Diego te lo confió, conviértelo en orden compartido para esta reunión."
            },
            {
              "type": "askChoice",
              "prompt": "¿Para qué servirá el cuaderno en la ronda familiar?",
              "options": [
                {
                  "label": "Para repartir turnos y asegurar que todas las voces entren con orden.",
                  "correct": true,
                  "actions": [
                    {
                      "type": "removeItem",
                      "itemId": "notebook",
                      "count": 1
                    },
                    {
                      "type": "addItem",
