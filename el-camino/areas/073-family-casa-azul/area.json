                      "count": 1
                    },
                    {
                      "type": "showDialogue",
                      "speaker": "Sofía",
                      "text": "Exacto. Lleva la leche a Elena en la Casa Roja; ella la usará para bajar la tensión de la cocina."
                    },
                    {
                      "type": "completeMission",
                      "missionId": "family-azul-roles"
                    }
                  ]
                },
                {
                  "label": "Para decidir que solo una persona hable toda la noche.",
                  "correct": false
                },
                {
                  "label": "Para terminar más rápido sin preguntas ni pausas.",
                  "correct": false
                }
              ],
              "wrongMessage": "No. Intenta otra vez."
